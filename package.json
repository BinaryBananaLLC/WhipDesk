{
  "name": "whipdesk",
  "version": "0.1.0",
  "private": true,
  "description": "WhipDesk — lightweight peer-to-peer remote desktop + AI-status notifications, controllable from a mobile browser.",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/BinaryBananaLLC/WhipDesk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BinaryBananaLLC/WhipDesk.git"
  },
  "bugs": {
    "url": "https://github.com/BinaryBananaLLC/WhipDesk/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "whipdesk": "npm run start --workspace whipdesk --",
    "dev": "npm run build:web && npm run whipdesk",
    "build:web": "npm run build --workspace @whipdesk/mobile-web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "verify": "npm run typecheck && npm run test",
    "notify": "node scripts/notify.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
